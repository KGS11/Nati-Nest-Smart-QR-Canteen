# Nati Nest Docker Compose environment template.
# Copy this file to .env for local Docker runs. Do not commit real secrets.

# Database
DATABASE_URL=postgresql://user:password@host:5432/nati_nest?sslmode=require&connection_limit=3

# Backend server
NODE_ENV=production
PORT=5000
CLIENT_URL=http://localhost
BACKEND_URL=http://localhost
APP_TIMEZONE=Asia/Kolkata

# JWT secrets
JWT_SECRET=replace-with-at-least-64-random-characters-for-staff-access-jwt
JWT_EXPIRES_IN=15m
SESSION_JWT_SECRET=replace-with-at-least-64-random-characters-for-customer-session-jwt
SESSION_JWT_EXPIRES_IN=12h

# Logging and observability
LOG_LEVEL=info
LOG_SLOW_REQUEST_MS=1000
LOG_SLOW_QUERY_MS=500
SENTRY_DSN=

# Rate limits
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=200
SOCKET_RATE_LIMIT_WINDOW_MS=60000
SOCKET_RATE_LIMIT_MAX=30

# Uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend build-time public variables
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_SOCKET_URL=http://localhost
NEXT_PUBLIC_APP_URL=http://localhost
NEXT_PUBLIC_APP_NAME=Nati Nest
NEXT_PUBLIC_SENTRY_DSN=

# Optional E2E variables
E2E_BASE_URL=http://localhost
E2E_TABLE_ID=
E2E_ADMIN_PHONE=
E2E_ADMIN_PASSWORD=
