datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  KITCHEN
  SERVER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PREPARING
  READY
  DELIVERED
  PAID
  CANCELLED
}

enum OrderItemStatus {
  ACTIVE
  REJECTED
}

enum PaymentMethod {
  CASH
  UPI
}

enum PaymentStatus {
  PENDING
  COMPLETED
}

enum AssistanceType {
  WATER
  BILL
  GENERAL
}

enum AssistanceStatus {
  PENDING
  RESOLVED
}

enum CateringLeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

model User {
  id           String   @id @default(uuid())
  name         String
  phone        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  paymentsVerified   Payment[]           @relation("VerifiedBy")
  assistanceResolved AssistanceRequest[] @relation("ResolvedBy")
  refreshTokens      RefreshToken[]
  dailyMenuAdded     DailyMenu[]         @relation("DailyMenuAddedBy")
  dailyMenuRemoved   DailyMenu[]         @relation("DailyMenuRemovedBy")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  familyId  String
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model RestaurantTable {
  id          String      @id @default(uuid())
  tableNumber String      @unique
  qrCodeUrl   String?
  status      TableStatus @default(AVAILABLE)
  createdAt   DateTime    @default(now())

  sessions TableSession[]

  @@index([status])
  @@map("restaurant_tables")
}

model MenuCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  items MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id          String   @id @default(uuid())
  categoryId  String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean  @default(true)
  isPopular   Boolean  @default(false)
  createdAt   DateTime @default(now())

  category   MenuCategory @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  dailyMenuEntries DailyMenu[]

  @@index([categoryId])
  @@index([isAvailable])
  @@map("menu_items")
}

model TableSession {
  id       String        @id @default(uuid())
  tableId  String
  status   SessionStatus @default(ACTIVE)
  openedAt DateTime      @default(now())
  closedAt DateTime?

  table              RestaurantTable     @relation(fields: [tableId], references: [id])
  orders             Order[]
  payment            Payment?
  feedback           Feedback?
  assistanceRequests AssistanceRequest[]
  cateringLeads      CateringLead[]

  @@index([tableId, status])
  @@index([openedAt])
  @@index([closedAt])
  @@index([status])
  @@map("table_sessions")
}

model Order {
  id          String      @id @default(uuid())
  sessionId   String
  status      OrderStatus @default(PLACED)
  placedAt    DateTime    @default(now())
  acceptedAt  DateTime?
  preparingAt DateTime?
  readyAt     DateTime?
  deliveredAt DateTime?
  paidAt      DateTime?

  session TableSession @relation(fields: [sessionId], references: [id])
  items   OrderItem[]

  @@index([sessionId, status])
  @@index([status, placedAt])
  @@index([placedAt])
  @@index([readyAt])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                  String          @id @default(uuid())
  orderId             String
  menuItemId          String
  quantity            Int
  unitPrice           Decimal         @db.Decimal(10, 2)
  specialInstructions String?
  status              OrderItemStatus @default(ACTIVE)
  createdAt           DateTime        @default(now())

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@index([status, createdAt])
  @@index([status])
  @@index([orderId, status])
  @@map("order_items")
}

model Payment {
  id            String        @id @default(uuid())
  sessionId     String        @unique
  verifiedById  String?
  totalAmount   Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  verifiedAt    DateTime?

  session    TableSession @relation(fields: [sessionId], references: [id])
  verifiedBy User?        @relation("VerifiedBy", fields: [verifiedById], references: [id])

  @@index([status, createdAt])
  @@index([status, verifiedAt])
  @@index([verifiedAt])
  @@index([status])
  @@map("payments")
}

model AssistanceRequest {
  id           String           @id @default(uuid())
  sessionId    String
  resolvedById String?
  requestType  AssistanceType
  status       AssistanceStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  resolvedAt   DateTime?

  session    TableSession @relation(fields: [sessionId], references: [id])
  resolvedBy User?        @relation("ResolvedBy", fields: [resolvedById], references: [id])

  @@index([sessionId, status])
  @@index([status, createdAt])
  @@map("assistance_requests")
}

model Feedback {
  id        String   @id @default(uuid())
  sessionId String   @unique
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  session TableSession @relation(fields: [sessionId], references: [id])

  @@index([createdAt])
  @@index([rating])
  @@map("feedback")
}

model CateringLead {
  id                   String             @id @default(uuid())
  sessionId            String?
  name                 String
  phone                String
  eventType            String
  eventDate            DateTime
  guestCount           Int
  location             String
  notes                String?
  preferredContactTime String?
  status               CateringLeadStatus @default(NEW)
  adminNotes           String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  session TableSession? @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([status, createdAt])
  @@index([eventDate])
  @@map("catering_leads")
}

model Settings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("settings")
}

model DailyMenu {
  id                String                  @id @default(uuid())
  menuItemId        String
  menuDate          DateTime                @db.Date
  addedById         String
  addedAt           DateTime                @default(now())
  removedAt         DateTime?
  removedById       String?
  removalReason     String?
  removalReasonType DailyMenuRemovalReason?

  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id])
  addedBy     User      @relation("DailyMenuAddedBy", fields: [addedById], references: [id])
  removedBy   User?     @relation("DailyMenuRemovedBy", fields: [removedById], references: [id])

  @@unique([menuItemId, menuDate])
  @@index([menuDate])
  @@index([menuItemId, menuDate])
  @@index([menuDate, removedAt])
  @@map("daily_menu")
}

enum DailyMenuRemovalReason {
  OUT_OF_STOCK
  INGREDIENT_FINISHED
  MACHINE_PROBLEM
  KITCHEN_CLOSED
  OTHER
}

