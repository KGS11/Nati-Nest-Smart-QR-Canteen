NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://nati_nest:nati_nest_password@postgres:5432/nati_nest?schema=public
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=15m
SESSION_JWT_SECRET=replace-with-at-least-32-random-session-characters
SESSION_JWT_EXPIRES_IN=12h
CLIENT_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
APP_TIMEZONE=Asia/Kolkata
SENTRY_DSN=
LOG_LEVEL=info
LOG_SLOW_REQUEST_MS=1000
LOG_SLOW_QUERY_MS=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=200
SOCKET_RATE_LIMIT_WINDOW_MS=60000
SOCKET_RATE_LIMIT_MAX=30
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
